# Database
POSTGRES_DB=your_database_name
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_secure_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Auth (required)
# JWT_SECRET_KEY=your-secret-key

# Role ID for new registrations (default 2, must exist in roles table)
# DEFAULT_USER_ROLE_ID=2

# Redis (for rate limiting / blocklist / sessions / pub-sub)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
# MAX_FAILED_ATTEMPTS=3
# BLOCK_TIME_MINUTES=10

# Instance ID (auto-generated if empty; set explicitly when running multiple instances)
# INSTANCE_ID=

# MinIO (S3-compatible storage)
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=product-images
MINIO_USE_SSL=false
MEDIA_URL_PREFIX=/media
IMAGE_MAX_SIZE_BYTES=5242880
IMAGE_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/gif